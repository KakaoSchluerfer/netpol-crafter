# ── Test mode defaults ────────────────────────────────────────────────────────
# This file is intentionally committed.  It contains NO real secrets.
# It provides safe defaults so `docker compose up` works out of the box
# without any configuration.  All external API calls are stubbed.

TEST_MODE=true

# ── Dummy OIDC values (auth is bypassed in test mode) ─────────────────────────
OIDC_CLIENT_ID=test-client-id
OIDC_CLIENT_SECRET=test-client-secret-not-real
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
OIDC_REDIRECT_URI=http://localhost:8501

# ── App ────────────────────────────────────────────────────────────────────────
# NOT suitable for production – generate a real key with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=test-secret-key-for-local-dev-only-do-not-use-in-production

# ── Kubernetes (stubbed in test mode – no cluster needed) ──────────────────────
K8S_IN_CLUSTER=false

# ── GitHub (stubbed in test mode – no PRs are created) ────────────────────────
GITHUB_REPO=test-org/network-policies
GITHUB_BASE_BRANCH=main
GITHUB_POLICIES_PATH=policies

# ── Debug ──────────────────────────────────────────────────────────────────────
DEBUG=true
