# ── Test mode defaults ────────────────────────────────────────────────────────
# This file is intentionally committed.  It contains NO real secrets.
# It provides safe defaults so `docker compose up` works out of the box
# without any configuration.  All external API calls are stubbed.

TEST_MODE=true

# ── OpenShift OAuth (bypassed in test mode) ───────────────────────────────────
OCP_CLIENT_ID=test-oauthclient
OCP_CLIENT_SECRET=test-secret-not-real
OCP_API_SERVER=https://api.test-cluster:6443
OCP_REDIRECT_URI=http://localhost:8501

# ── Exporter ──────────────────────────────────────────────────────────────────
EXPORTER_URL=http://localhost:8080

# ── Cluster display ───────────────────────────────────────────────────────────
CLUSTER_NAME=test-cluster

# ── App ────────────────────────────────────────────────────────────────────────
# NOT suitable for production – generate a real key with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=test-secret-key-for-local-dev-only-do-not-use-in-production

# ── Debug ──────────────────────────────────────────────────────────────────────
DEBUG=true
