# ── Azure AD / Entra ID OIDC ─────────────────────────────────────────────────
# App registration Client ID (from Azure portal)
OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App registration Client Secret
OIDC_CLIENT_SECRET=your-client-secret-here

# Azure AD Tenant ID
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Must match exactly what is registered in Azure as a Redirect URI
# For local dev: http://localhost:8501
# For production: https://netpol-crafter.internal.yourdomain.com
OIDC_REDIRECT_URI=http://localhost:8501

# Space-separated OIDC scopes
OIDC_SCOPES=openid profile email

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=replace-with-a-strong-random-secret

# Set to "true" when running inside an OpenShift/K8s Pod
K8S_IN_CLUSTER=false

# Only needed when K8S_IN_CLUSTER=false and you want to override the active kubeconfig context
# K8S_API_SERVER=https://api.your-cluster.example.com:6443
# K8S_CA_CERT_PATH=/path/to/ca.crt
# KUBECONFIG=/home/user/.kube/config

# ── GitHub Integration ────────────────────────────────────────────────────────
# Target repository that ArgoCD watches for NetworkPolicy manifests
GITHUB_REPO=your-org/network-policies

# Base branch PRs target (ArgoCD source branch)
GITHUB_BASE_BRANCH=main

# Path prefix inside the repo where policy YAMLs are stored.
# Policies are committed to: {GITHUB_POLICIES_PATH}/{namespace}/{policy-name}.yaml
GITHUB_POLICIES_PATH=policies

# ── GitHub Auth (choose ONE of the two options below) ─────────────────────────
#
# OPTION A – GitHub App (recommended for production)
# Create an App at https://github.com/organizations/{org}/settings/apps
# Required permissions: Contents (read/write), Pull requests (read/write)
# Install it on the target repo and note the Installation ID.
#
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=78901234
#
# Provide the private key either as a file path:
# GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem
# OR as inline PEM content (use \n for newlines if set via env var):
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...
#
# OPTION B – Personal Access Token (dev / small teams only)
# Fine-grained PAT with: Contents (read/write), Pull requests (read/write)
# on the target repo only. Rotate regularly.
#
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=replace-with-a-strong-random-secret

# Set to "true" when running inside an OpenShift/K8s Pod
K8S_IN_CLUSTER=false

# Only needed when K8S_IN_CLUSTER=false and you want to override the active kubeconfig context
# K8S_API_SERVER=https://api.your-cluster.example.com:6443
# K8S_CA_CERT_PATH=/path/to/ca.crt
# KUBECONFIG=/home/user/.kube/config

# Set to "true" to show stack traces in the UI (never in production)
DEBUG=false
