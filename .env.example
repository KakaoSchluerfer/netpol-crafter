# ── OpenShift OAuth ───────────────────────────────────────────────────────────
#
# The OAuthClient must be pre-registered on the cluster, e.g.:
#   oc create -f - <<EOF
#   apiVersion: oauth.openshift.io/v1
#   kind: OAuthClient
#   metadata:
#     name: pharos-frontend
#   secret: "your-client-secret-here"
#   redirectURIs:
#     - https://pharos-frontend.internal.yourdomain.com
#   grantMethod: auto
#   EOF

# Registered OAuthClient name
OCP_CLIENT_ID=pharos-frontend

# OAuthClient secret (set in the OAuthClient object above)
OCP_CLIENT_SECRET=your-client-secret-here

# OpenShift API server URL
OCP_API_SERVER=https://api.your-cluster.example.com:6443

# Must match exactly what is registered in the OAuthClient redirectURIs
# For local dev: http://localhost:8501
# For production: https://pharos-frontend.internal.yourdomain.com
OCP_REDIRECT_URI=http://localhost:8501

# Path to a PEM CA bundle for TLS verification.
# Leave empty to use system CAs.
# OCP_CA_CERT_PATH=/etc/netpol-certs/cluster-ca.crt

# ── Exporter ──────────────────────────────────────────────────────────────────
# URL of the pharos-exporter sidecar/service
EXPORTER_URL=http://pharos-exporter:8080

# ── Cluster display ───────────────────────────────────────────────────────────
# Human-readable name shown in the sidebar
CLUSTER_NAME=production

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=replace-with-a-strong-random-secret

# Set to "true" to show stack traces in the UI (never in production)
DEBUG=false
